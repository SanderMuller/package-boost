{
    "name": "sandermuller/package-boost",
    "description": "AI-assisted development tooling for Laravel package developers",
    "keywords": [
        "laravel",
        "package-development",
        "ai",
        "boost",
        "testbench"
    ],
    "homepage": "https://github.com/sandermuller/package-boost",
    "license": "MIT",
    "authors": [
        {
            "name": "Sander Muller",
            "email": "github@scode.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0||^12.0||^13.0",
        "illuminate/support": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0||^10.0",
        "pestphp/pest": "^3.0||^4.0"
    },
    "autoload": {
        "psr-4": {
            "SanderMuller\\PackageBoost\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SanderMuller\\PackageBoost\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SanderMuller\\PackageBoost\\PackageBoostServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
